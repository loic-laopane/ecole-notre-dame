APP_ENV=dev
APP_SECRET=change_me_32_chars_random_string

# PostgreSQL
DATABASE_URL="postgresql://ndsl_user:ndsl_secret@127.0.0.1:5432/ndsl?serverVersion=16&charset=utf8"

# JWT
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=ndsl_jwt_passphrase
JWT_TOKEN_TTL=3600

# OAuth2 – Google (remplir avec vos credentials Google Console)
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth2 – Microsoft (optionnel)
OAUTH_MICROSOFT_CLIENT_ID=your_microsoft_client_id
OAUTH_MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
OAUTH_MICROSOFT_TENANT=common

# CORS
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
